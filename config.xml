<?xml version="1.0" encoding="UTF-8"?>
<widget id="com.foodzy.app" version="1.0.1" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>Foodzy</name>
    <description>Foodzy — Food in minutes. Quick-commerce grocery delivery app.</description>
    <author email="dev@foodzy.app" href="https://foodzy.app">Foodzy Team</author>

    <!-- Entry point: must match your file in www/ (Foodzy's app file, renamed to index.html) -->
    <content src="index.html" />

    <!-- Network + external-link access -->
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />

    <!-- ===== General Preferences ===== -->
    <preference name="Orientation" value="portrait" />
    <preference name="Fullscreen" value="false" />
    <preference name="AndroidXEnabled" value="true" />
    <preference name="DisallowOverscroll" value="true" />

    <!-- Foodzy handles its own internal scrolling in JS/CSS, so the native
         WebView page-scroll (and its rubber-band bounce) is turned off. -->
    <preference name="ScrollEnabled" value="false" />
    <preference name="BackupWebStorage" value="none" />

    <!-- Splash screen -->
    <preference name="SplashMaintainAspectRatio" value="true" />
    <preference name="FadeSplashScreenDuration" value="300" />
    <preference name="SplashShowOnlyFirstTime" value="false" />
    <preference name="SplashScreen" value="screen" />
    <preference name="SplashScreenDelay" value="3000" />

    <!-- Keep these current with Google Play's latest required API levels
         before you publish — check the Play Console "Target API level"
         requirement page, these numbers can change year to year. -->
    <preference name="android-minSdkVersion" value="24" />
    <preference name="android-targetSdkVersion" value="34" />

    <!-- ===== Geolocation Plugin =====
         This is what makes navigator.geolocation.getCurrentPosition() in
         Foodzy's JS trigger Android's native "Allow Foodzy to access this
         device's location?" permission dialog. -->
    <plugin name="cordova-plugin-geolocation" spec="~4.1.0">
        <variable name="GPS_REQUIRED" value="true" />
    </plugin>

    <!-- ===== Android Platform ===== -->
    <platform name="android">
        <allow-intent href="market:*" />

        <!-- Injected into AndroidManifest.xml on every build -->
        <config-file target="AndroidManifest.xml" parent="/*">
            <uses-permission android:name="android.permission.INTERNET" />
            <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
            <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
            <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
            <uses-permission android:name="android.permission.ACCESS_LOCATION_EXTRA_COMMANDS" />
        </config-file>
    </platform>
</widget>
